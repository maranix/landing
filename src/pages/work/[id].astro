---
import { getCollection, getEntry, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";

export async function getStaticPaths() {
    const entries = await getCollection("project");
    return entries.map((entry) => ({
        params: { id: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Check if a corresponding blog post exists
const correspondingBlog = await getEntry("blog", entry.id);
---

<Layout title={`${entry.data.title} | RAMAN VERMA`} currentPath="/work">
    <main class="main-content container">
        <div class="back-link">
            <a href="/work">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to Work
            </a>
        </div>

        <PageHeader meta={entry.data.type} subtitle={entry.data.description}>
            <h1>{entry.data.title}</h1>
        </PageHeader>

        <div class="project-tags">
            {
                entry.data.tags.map((tag) => (
                    <span class="project-tag">{tag}</span>
                ))
            }
            {entry.data.aiGeneratedProject && (
                <span class="project-tag ai-tag">
                    <span class="material-symbols-outlined" style="font-size: 14px;">auto_awesome</span>
                    Vibe Coded Project
                </span>
            )}
            {entry.data.aiGeneratedContent && (
                <span class="project-tag ai-tag">
                    <span class="material-symbols-outlined" style="font-size: 14px;">edit_note</span>
                    AI Written Content
                </span>
            )}
        </div>

        <div class="project-links">
            {entry.data.github && (
                <a href={entry.data.github} target="_blank" rel="noopener noreferrer" class="btn-primary">
                    <span class="material-symbols-outlined">code</span>
                    View on GitHub
                </a>
            )}
            {entry.data.website && (
                <a href={entry.data.website} target="_blank" rel="noopener noreferrer" class="btn-primary">
                    <span class="material-symbols-outlined">language</span>
                    Package Website
                </a>
            )}
            {correspondingBlog && (
                <a href={`/blog/${correspondingBlog.id}`} class="btn-secondary">
                    <span class="material-symbols-outlined">article</span>
                    Read Blog Post
                </a>
            )}
        </div>

        <div class="content-divider"></div>

        <article
            class="post-body markdown-content"
            style="max-width: 800px; margin: 0 auto; width: 100%; display: block;"
        >
            <Content />
        </article>
    </main>
</Layout>

<style>
    .back-link {
        margin-bottom: 4rem;
    }
    .back-link a {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-secondary);
        font-size: 0.875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.2s ease;
    }
    .back-link a:hover {
        color: var(--accent-tertiary);
    }

    .project-tags {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 3rem;
        margin-bottom: 2rem;
    }

    .project-tag {
        font-size: 0.7rem;
        padding: 0.25rem 0.75rem;
        background-color: var(--surface-high);
        color: var(--text-secondary);
        text-transform: uppercase;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        font-weight: 500;
        letter-spacing: 0.05em;
    }

    .ai-tag {
        background-color: var(--surface-low);
        color: var(--accent-primary);
        border: 1px solid var(--border-color);
    }

    .content-divider {
        height: 1px;
        background-color: var(--border-color);
        margin-bottom: 4rem;
    }

    .post-body {
        max-width: 800px;
        margin: 0 auto;
        width: 100%;
    }

    .markdown-content :global(h1) {
        margin-bottom: 2rem;
        font-size: clamp(2rem, 4vw, 3rem);
    }
    .markdown-content :global(h2) {
        margin-top: 3rem;
        margin-bottom: 1.5rem;
    }
    .markdown-content :global(p) {
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }
    .markdown-content :global(ul),
    .markdown-content :global(ol) {
        margin-bottom: 1.5rem;
        padding-left: 1.5rem;
        color: var(--text-secondary);
    }
    .markdown-content :global(li) {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }
    
    .project-links {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        margin-bottom: 4rem;
    }

    .markdown-content :global(a) {
        color: var(--accent-primary);
        text-decoration: none;
        font-weight: 500;
    }

    .markdown-content :global(a:hover) {
        text-decoration: underline;
    }
</style>
