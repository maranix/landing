---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import WorkRow from "../components/WorkRow.astro";
import PageHeader from "../components/PageHeader.astro";

const projects = await getCollection("project");
const sortedProjects = projects.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Work | RAMAN VERMA" currentPath="/work">
    <main class="main-content container">
        <PageHeader
            meta="Showcase"
            subtitle="Things I've designed, built, and deemed worth sharing."
            listContent={true}
        >
            <h1>
                <span class="highlight">FEATURED</span> / <br /><span
                    class="highlight">BUILDS</span
                >
            </h1>
        </PageHeader>

        <div class="work-list">
            {
                sortedProjects.map((project) => (
                    <WorkRow
                        title={project.data.title}
                        type={project.data.type || "Library"}
                        stack={project.data.stack || []}
                        description={project.data.description}
                        href={`/work/${project.id}`}
                    />
                ))
            }
        </div>

        <!-- <div class="work-footer">
            <div>
                <span class="stat-label">Total Build Count</span>
                <span class="stat-value">1,204</span>
            </div>
            <div>
                <span class="stat-label">Global Latency Avg</span>
                <span class="stat-value">12ms</span>
            </div>
            <div>
                <span class="stat-label">Stack Integrity</span>
                <span class="stat-value stat-value-highlight">99.9%</span>
            </div>
        </div> -->
    </main>
</Layout>

<style>
    .work-table-header {
        display: grid;
        grid-template-columns: 4fr 2fr 2fr 3fr 1fr;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 700;
        color: var(--text-tertiary);
    }

