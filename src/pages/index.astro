---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BlogEntry from "../components/BlogEntry.astro";
import Section from "../components/Section.astro";

const allPosts = await getCollection("blog");
const featuredPosts = allPosts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 4);

const allProjects = await getCollection("project");
const featuredProjectIds = [
    "aarnote",
    "analyzer-kit-annotation",
    "build-runner-hook",
    "http-toolkit",
];
const featuredProjects = allProjects
    .filter((p) => featuredProjectIds.includes(p.id))
    .sort(
        (a, b) =>
            featuredProjectIds.indexOf(a.id) - featuredProjectIds.indexOf(b.id),
    );
---

<Layout title="RAMAN VERMA | Software Engineer" currentPath="/">
    <main class="main-content container">
        <section class="hero">
            <h1>RAMAN VERMA</h1>
            <p>
                <span class="text-accent-secondary" style={"font-weight: 500"}
                    >Software Engineer</span
                >
                building robust applications and open-source solutions. Specializing
                in cross-platform mobile development, scalable backend services, cloud
                infrastructure, and AI integrations.
            </p>
            <div class="hero-actions">
                <a href="/work" class="btn-primary">
                    View Work
                    <span class="material-symbols-outlined">arrow_forward</span>
                </a>
                <a href="mailto:ramanverma4183@gmail.com" class="btn-secondary">
                    Get In Touch
                </a>
            </div>
        </section>

        <Section id="work" title="Featured Work">
            <div class="project-grid">
                {
                    featuredProjects.map((project) => (
                        <ProjectCard
                            version={project.data.version}
                            icon={project.data.icon || "hub"}
                            title={project.data.title}
                            description={project.data.description}
                            tags={project.data.tags.slice(0, 3)}
                            href={`/work/${project.id}`}
                        />
                    ))
                }
            </div>
        </Section>

        <Section id="blog" title="Featured Posts">
            <div class="blog-list">
                {
                    featuredPosts.map((post) => (
                        <BlogEntry
                            date={post.data.date}
                            title={post.data.title}
                            category={post.data.category}
                            href={`/blog/${post.id}`}
                        />
                    ))
                }
            </div>
        </Section>

        <Section title="Technical Stack">
            <div class="capabilities-grid">
                <!-- Mobile Section -->
                <div>
                    <h4 class="capability-title">
                        <span class="capability-dot dot-primary"></span>
                        Mobile & Cross-Platform
                    </h4>
                    <ul class="capability-list">
                        <li>Flutter & Advanced Dart</li>
                        <li>React Native</li>
                        <li>FFI / Platform Channels</li>
                        <li>Native iOS / Android Integrations</li>
                        <li>Reactive State Management</li>
                        <li>Store Deployments (Play Store & App Store)</li>
                    </ul>
                </div>

                <!-- Web Section -->
                <div>
                    <h4 class="capability-title">
                        <span class="capability-dot dot-secondary"></span>
                        Web Development
                    </h4>
                    <ul class="capability-list">
                        <li>TypeScript & JavaScript</li>
                        <li>Modern Web Frameworks</li>
                        <li>Responsive UI & Web Architecture</li>
                        <li>Web Performance Optimization</li>
                    </ul>
                </div>

                <!-- Backend Section -->
                <div>
                    <h4 class="capability-title">
                        <span class="capability-dot dot-tertiary"></span>
                        Backend & Cloud
                    </h4>
                    <ul class="capability-list">
                        <li>Micro & Monolithic Services</li>
                        <li>Serverless Architectures</li>
                        <li>Containerization & Orchestration</li>
                        <li>CI/CD Automation</li>
                        <li>Database Design & Management</li>
                        <li>Cloud Infrastructure</li>
                        <li>AI System Integrations</li>
                        <li>API Design & Optimization</li>
                    </ul>
                </div>

                <!-- Systems Section -->
                <div>
                    <h4 class="capability-title">
                        <span class="capability-dot dot-quaternary"></span>
                        Systems & Tooling
                    </h4>
                    <ul class="capability-list">
                        <li>Framework Internals & Custom Linters</li>
                        <li>Open-Source Package Development</li>
                        <li>Concurrency & Async Logic</li>
                        <li>Memory & Resource Management</li>
                        <li>Performance Profiling</li>
                        <li>Security Best Practices</li>
                    </ul>
                </div>
            </div>
        </Section>
    </main>
</Layout>

<style>
    /* Home specific */
    .hero {
        margin-bottom: 8rem;
        max-width: 600px;
    }

    .hero p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        font-weight: 300;
        line-height: 1.6;
        margin-top: 1.5rem;
    }

    .hero-actions {
        margin-top: 3rem;
        display: flex;
        gap: 2rem;
        align-items: center;
    }

    .btn-primary {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-primary);
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .btn-primary .material-symbols-outlined {
        transition: transform 0.2s ease;
    }

    .btn-primary:hover .material-symbols-outlined {
        transform: translateX(4px);
    }

    .btn-secondary {
        color: var(--text-secondary);
        font-size: 1rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.2s ease;
    }

    .btn-secondary:hover {
        color: var(--text-primary);
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 3rem;
        margin-bottom: 8rem;
    }

    .blog-list {
        margin-bottom: 8rem;
    }

    /* Capabilities (Home) */
    .capabilities-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 4rem;
        margin-bottom: 6rem;
    }

    .capability-title {
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .capability-dot {
        width: 6px;
        height: 6px;
    }

    .dot-primary {
        background-color: var(--accent-primary);
    }
    .dot-secondary {
        background-color: var(--accent-secondary);
    }
    .dot-tertiary {
        background-color: var(--accent-tertiary);
    }
    .dot-quaternary {
        background-color: var(--text-primary);
    }

    .capability-list {
        list-style: none;
    }

    .capability-list li {
        color: var(--text-secondary);
        font-weight: 300;
        margin-bottom: 1rem;
    }
</style>
