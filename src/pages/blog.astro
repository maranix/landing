---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BlogEntry from "../components/BlogEntry.astro";
import PageHeader from "../components/PageHeader.astro";

const allPosts = await getCollection("blog");
const sortedPosts = allPosts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Blog | RAMAN VERMA" currentPath="/blog">
    <main class="main-content container">
        <PageHeader
            meta="MUSINGS & NOTES"
            subtitle="Documenting what I build, what breaks, and what I learn along the way."
            listContent={true}
        >
            <h1>
                <span class="highlight">THOUGHTS</span> / <br /><span
                    class="highlight">THEORIES</span
                >
            </h1>
        </PageHeader>

        <section>
            {
                sortedPosts.map((post) => (
                    <BlogEntry
                        date={post.data.date}
                        title={post.data.title}
                        category={post.data.category}
                        href={`/blog/${post.id}`}
                    />
                ))
            }
        </section>

        <section class="pagination">
            <div class="pagination-controls">
                <button class="page-btn">Previous</button>
                <button class="page-btn" disabled>Next</button>
            </div>
            <div class="pagination-info">
                <span class="pagination-label">Total_entries:</span>
                <span class="pagination-total text-accent-primary"
                    >{sortedPosts.length}</span
                >
            </div>
        </section>
    </main>
</Layout>

<style>
    .pagination {
        margin-top: 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pagination-controls {
        display: flex;
        gap: 2rem;
    }

    .page-btn {
        background: none;
        border: none;
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-primary);
        cursor: pointer;
        padding-bottom: 0.25rem;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
        font-family: var(--font-main);
    }

    .page-btn:hover:not(:disabled) {
        color: var(--accent-tertiary);
        border-bottom-color: var(--accent-tertiary);
    }

    .page-btn:disabled {
        color: var(--text-tertiary);
        cursor: not-allowed;
    }

    .pagination-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .pagination-label {
        font-size: 0.8125rem;
        text-transform: uppercase;
        color: var(--text-tertiary);
    }

    .pagination-total {
        font-size: 1rem;
        font-weight: 700;
    }
</style>
