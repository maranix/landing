---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    currentPath?: string;
}

const { title, currentPath } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Portfolio of Raman Verma, a Software Engineer specializing in cross-platform mobile development, backend services, and AI integrations.">
    <meta property="og:title" content={title}>
    <meta property="og:description" content="Software Engineer building robust applications and open-source solutions.">
    <meta property="og:type" content="website">
    <title>{title}</title>
</head>
<body>
    <Nav currentPath={currentPath} />
    <slot />
    <Footer />
</body>
</html>
