---
interface Props {
    title: string;
    type: string;
    stack: string[];
    description: string;
    href: string;
}

const { title, type, stack, description, href } = Astro.props;
---

<div class={`work-row`} onclick={`window.location.href='${href}'`}>
    <h2 class="work-row-title">{title}</h2>
    <div><span class="work-row-type">{type}</span></div>
    <div class="work-row-stack">
        <div class="stack-tags">
            {stack.map((item) => (
                <span class="stack-tag">{item}</span>
            ))}
        </div>
    </div>
    <div class="work-row-desc">{description}</div>
    <div class="work-row-icon">
        <span class="material-symbols-outlined">arrow_outward</span>
    </div>
</div>

<style>
    .work-row {
        display: grid;
        grid-template-columns: 4fr 1.5fr 2fr 4fr 0.5fr;
        gap: 2rem;
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--border-color);
        align-items: center;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    .work-row:hover {
        background-color: var(--surface);
    }

    .work-row-title {
        font-size: 1.75rem;
        font-weight: 700;
        text-transform: uppercase;
        transition: color 0.2s ease;
        line-height: 1;
    }

    .work-row:hover .work-row-title {
        color: var(--accent-tertiary);
    }

    .work-row-type {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        background-color: var(--surface-high);
        font-size: 0.8125rem;
        text-transform: uppercase;
        color: var(--text-primary);
    }

    .work-row-stack {
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-secondary);
    }

    .stack-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .stack-tag {
        font-size: 0.625rem;
        padding: 0.15rem 0.5rem;
        background-color: var(--surface-low);
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 600;
    }

    .work-row-desc {
        font-size: 1rem;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .work-row-icon {
        text-align: right;
        color: var(--accent-primary);
    }

    .work-row .material-symbols-outlined {
        transition: transform 0.2s ease;
    }

    .work-row:hover .material-symbols-outlined {
        transform: translate(4px, -4px);
    }

    @media (max-width: 1024px) {
        .work-row {
            grid-template-columns: 4fr 1.5fr 2fr 0.5fr;
        }
        .work-row-desc {
            display: none;
        }
    }

    @media (max-width: 768px) {
        .work-row {
            grid-template-columns: 1fr;
            gap: 1rem;
            padding: 1.5rem 0;
        }

        .work-row-type {
            display: inline-block;
            width: fit-content;
            margin-top: 0.5rem;
        }

        .work-row-icon {
            display: none;
        }

        .stack-tags {
            margin: 0.5rem 0;
        }
    }
</style>
