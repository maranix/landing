---
const { currentPath = '' } = Astro.props;
---

<nav class="nav">
    <div class="nav-container">
        <div class="nav-brand">RAMAN VERMA</div>
        <div class="nav-links">
            <a class={`nav-link ${currentPath === '/' ? 'active' : ''}`} href="/">HOME</a>
            <a class={`nav-link ${currentPath === '/work' ? 'active' : ''}`} href="/work">WORK</a>
            <a class={`nav-link ${currentPath === '/blog' ? 'active' : ''}`} href="/blog">BLOG</a>
        </div>
        <div class="nav-mobile-menu">
            <span class="material-symbols-outlined">menu</span>
        </div>
    </div>
</nav>

<style>
/* Navigation */
.nav {
    position: fixed;
    top: 0;
    width: 100%;
    height: 5rem;
    background-color: rgba(14, 14, 14, 0.8);
    backdrop-filter: blur(16px);
    z-index: 50;
    display: flex;
    justify-content: center;
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 1440px;
    padding: 0 2rem;
}

.nav-brand {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -0.05em;
}

.nav-links {
    display: flex;
    gap: 2.5rem;
}

.nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color 0.2s ease;
}

.nav-link:hover {
    color: var(--accent-tertiary);
}

.nav-link.active {
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: var(--accent-tertiary);
    text-underline-offset: 6px;
}

.nav-mobile-menu {
    display: none;
    color: var(--text-secondary);
    cursor: pointer;
}

@media (max-width: 768px) {
    .nav-links {
        display: none;
    }

    .nav-mobile-menu {
        display: block;
    }
}
</style>
