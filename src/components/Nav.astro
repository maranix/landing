---
const { currentPath = "" } = Astro.props;
---

<nav class="nav">
    <div class="nav-container">
        <div class="nav-brand">
            <a href="/">/-(^_^)-\</a>
        </div>
        <div class="nav-links">
            <a
                class={`nav-link ${currentPath === "/" ? "active" : ""}`}
                href="/">HOME</a
            >
            <a
                class={`nav-link ${currentPath === "/work" ? "active" : ""}`}
                href="/work">WORK</a
            >
            <a
                class={`nav-link ${currentPath === "/blog" ? "active" : ""}`}
                href="/blog">BLOG</a
            >
        </div>
        <div class="nav-mobile-menu">
            <span class="material-symbols-outlined">menu</span>
        </div>
    </div>
</nav>

<div class="mobile-nav-overlay">
    <div class="mobile-nav-content">
        <span class="material-symbols-outlined close-menu">close</span>
        <div class="mobile-links">
            <a
                class={`nav-link ${currentPath === "/" ? "active" : ""}`}
                href="/">HOME</a
            >
            <a
                class={`nav-link ${currentPath === "/work" ? "active" : ""}`}
                href="/work">WORK</a
            >
            <a
                class={`nav-link ${currentPath === "/blog" ? "active" : ""}`}
                href="/blog">BLOG</a
            >
        </div>
    </div>
</div>

<script>
    function setupMenu() {
        const menuBtn = document.querySelector(".nav-mobile-menu");
        const overlay = document.querySelector(".mobile-nav-overlay");
        const closeBtn = document.querySelector(".close-menu");

        if (menuBtn && overlay && closeBtn) {
            menuBtn.addEventListener("click", () => {
                overlay.classList.add("open");
                document.body.style.overflow = "hidden";
            });

            closeBtn.addEventListener("click", () => {
                overlay.classList.remove("open");
                document.body.style.overflow = "";
            });

            // Close on link click
            const links = overlay.querySelectorAll(".nav-link");
            links.forEach((link) => {
                link.addEventListener("click", () => {
                    overlay.classList.remove("open");
                    document.body.style.overflow = "";
                });
            });
        }
    }

    // Run on initial load
    setupMenu();
</script>

<style>
    /* Navigation */
    .nav {
        position: fixed;
        top: 0;
        width: 100%;
        height: 5rem;
        background-color: var(--bg-color);
        background-color: color-mix(in srgb, var(--bg-color), transparent 30%);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-color);
        z-index: 50;
        display: flex;
        justify-content: center;
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        max-width: 1440px;
        padding: 0 2rem;
    }

    .nav-brand {
        font-size: 1.5rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: -0.05em;
    }

    .nav-links {
        display: flex;
        gap: 2.5rem;
    }

    .nav-link {
        font-size: 1rem;
        font-weight: 500;
        text-transform: uppercase;
        color: var(--text-secondary);
        transition: color 0.2s ease;
    }

    .nav-link:hover {
        color: var(--accent-tertiary);
    }

    .nav-link.active {
        font-weight: 700;
        color: var(--text-primary);
        text-decoration: underline;
        text-decoration-color: var(--accent-tertiary);
        text-underline-offset: 6px;
    }

    .nav-mobile-menu {
        display: none;
        color: var(--text-secondary);
        cursor: pointer;
        transition:
            color 0.2s ease,
            transform 0.2s ease;
    }

    .nav-mobile-menu:hover {
        color: var(--text-primary);
        transform: scale(1.1);
    }

    /* Mobile Overlay */
    .mobile-nav-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background-color: var(--bg-color);
        z-index: 100;
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .mobile-nav-overlay.open {
        display: flex;
        opacity: 1;
    }

    .mobile-nav-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }

    .close-menu {
        position: absolute;
        top: 1.5rem;
        right: 2rem;
        font-size: 2rem;
        cursor: pointer;
        color: var(--text-secondary);
        transition:
            color 0.2s ease,
            transform 0.2s ease;
    }

    .close-menu:hover {
        color: var(--text-primary);
        transform: scale(1.1);
    }

    .mobile-links {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: center;
    }

    .mobile-links .nav-link {
        font-size: 1.5rem;
    }

    @media (max-width: 768px) {
        .nav-links {
            display: none;
        }

        .nav-mobile-menu {
            display: block;
        }
    }
</style>
