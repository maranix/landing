---
interface Props {
    meta: string;
    subtitle: string;
    listContent?: boolean;
}

const { meta, subtitle, listContent = false } = Astro.props;
---

<header class="page-header" style={listContent ? "margin-bottom: 8rem;" : ""}>
    <div style="max-width: 600px;">
        <span class="page-header-meta">{meta}</span>
        <slot />
        <div class="page-header-sub">
            <p class="page-header-desc">{subtitle}</p>
        </div>
    </div>
</header>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
    }

    .page-header-meta {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent-tertiary);
        margin-bottom: 1rem;
        display: block;
    }

    .page-header-sub {
        margin-top: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-header-desc {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-secondary);
    }

    @media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
