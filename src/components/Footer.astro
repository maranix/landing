    }

    .footer-links {
        display: flex;
        gap: 2rem;
    }

    .footer-link {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-tertiary);
        transition: color 0.2s ease;
    }

    .footer-link:hover {
        color: var(--accent-tertiary);
        text-decoration: underline;
    }

    @media (max-width: 768px) {
        .footer-container {
